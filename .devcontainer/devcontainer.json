{
  "name": "tsunami-dev-ubuntu-24.04",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "developer",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },

  "remoteUser": "developer",
  "updateRemoteUserUID": true,

  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",

  "containerEnv": {
    "PYTHONPATH": "/workspace",
    "STREAMLIT_SERVER_HEADLESS": "true",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  },

  "forwardPorts": [8501, 8888],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit",
      "onAutoForward": "notify"
    },
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "jupyter.askForKernelRestart": false,
        "yaml.format.enable": true
      },
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint"
      ],
      "mcp": {
        "servers": {
          "filesystem": {
            "command": "mcp-server-filesystem",
            "args": ["/workspace"]
          },
          "fetch": {
            "command": "mcp-server-fetch"
          }
        }
      }
    }
  },

  "postCreateCommand": "bash -lc 'python --version && pip --version && node --version && npm --version && if [ -f requirements.txt ]; then pip install -r requirements.txt; fi && if [ -f requirements-dev.txt ]; then pip install -r requirements-dev.txt; fi'",

  "shutdownAction": "stopContainer"
}